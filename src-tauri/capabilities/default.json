{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the settings window",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-unregister",
    "opener:default",
    "dialog:allow-open"
  ]
}
